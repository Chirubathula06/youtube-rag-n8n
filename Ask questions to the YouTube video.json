    {
      "parameters": {
        "jsCode": "const question = $('When chat message received').first().json.chatInput;\n\nconst chunks = items.map((item, index) => {\n  let text = \"\";\n\n  if (item.json.pageContent) {\n    text = item.json.pageContent;\n  } else if (item.json.document?.pageContent) {\n    text = item.json.document.pageContent;\n  } else if (item.json.response?.[0]?.text) {\n    try {\n      const parsed = JSON.parse(item.json.response[0].text);\n      text = parsed.pageContent;\n    } catch (e) {\n      text = item.json.response[0].text;\n    }\n  } else {\n    text = JSON.stringify(item.json);\n  }\n\n  return `Chunk ${index + 1}:\\n${text}`;\n});\n\nreturn [\n  {\n    json: {\n      question,\n      context: chunks.join(\"\\n\\n---\\n\\n\")\n    }\n  }\n];"
      },
